import java.util.*;

class Solution {

    public long gcdSum(int[] nums) {

        int n = nums.length;

        int[] prefixGcd = new int[n];

        int maxValue = 0;

        // Construct prefixGcd
        for (int i = 0; i < n; i++) {

            maxValue = Math.max(maxValue, nums[i]);

            prefixGcd[i] = gcd(nums[i], maxValue);
        }

        // Sort prefixGcd
        Arrays.sort(prefixGcd);

        long sum = 0;

        // Pair smallest with largest
        for (int i = 0; i < n / 2; i++) {

            int left = prefixGcd[i];

            int right = prefixGcd[n - 1 - i];

            sum += gcd(left, right);
        }

        return sum;
    }

    // Euclidean Algorithm
    private int gcd(int a, int b) {

        while (b != 0) {

            int temp = b;
            b = a % b;
            a = temp;
        }

        return a;
    }
}
